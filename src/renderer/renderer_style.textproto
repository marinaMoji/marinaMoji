# proto-file: third_party/mozc/src/protocol/renderer_style.proto
# proto-message: RendererStyle
# marinaMoji: white panel; borders match macOS toolbar (1pt, rgba(0,0,0,0.08)).
# Inset from rounded panel edge (scales with font size).
window_border: 4
corner_radius: 10
scrollbar_width: 4
row_rect_padding: 3
window_background_color { r: 255 g: 255 b: 255 }
border_color { r: 0 g: 0 b: 0 a: 0.08 }
shortcut_style {
  font_size: 14
  foreground_color { r: 119 g: 119 b: 119 }
  left_padding: 8
  right_padding: 8
}
gap1_style { font_size: 14 }
candidate_style { font_size: 14 }
description_style {
  font_size: 12
  foreground_color { r: 136 g: 136 b: 136 }
  right_padding: 8
}
# We want to ensure that the candidate window is at least wide
# enough to render "そのほかの文字種  " as a candidate.
column_minimum_width_string: "そのほかの文字種  "
footer_style { font_size: 14 left_padding: 8 right_padding: 8 }
footer_sub_label_style {
  font_size: 10
  foreground_color { r: 167 g: 167 b: 167 }
  left_padding: 4
  right_padding: 4
}
footer_border_colors { r: 0 g: 0 b: 0 a: 0.08 }
footer_top_color { r: 255 g: 255 b: 255 }
footer_bottom_color { r: 255 g: 255 b: 255 }
logo_file_name: "candidate_window_logo.tiff"
logo_svg_file_name: "toolbar_icons/logo_long_light.svg"
focused_background_color { r: 243 g: 244 b: 255 }
focused_border_color { r: 0 g: 0 b: 0 a: 0.08 }
scrollbar_background_color { r: 240 g: 242 b: 245 }
scrollbar_indicator_color { r: 0 g: 0 b: 0 a: 0.08 }
infolist_style {
  caption_string: "用例"
  caption_height: 20
  caption_padding: 1
  caption_style { font_size: 12 left_padding: 2 }
  caption_background_color { r: 243 g: 244 b: 255 }
  window_border: 4
  row_rect_padding: 2
  window_width: 300
  title_style { font_size: 15 left_padding: 5 }
  description_style { font_size: 12 left_padding: 15 }
  border_color { r: 0 g: 0 b: 0 a: 0.08 }
  focused_background_color { r: 243 g: 244 b: 255 }
  focused_border_color { r: 0 g: 0 b: 0 a: 0.08 }
}
